{
  "name": "server",
  "version": "1.0.0",
  "description": "It is for the hostel management website",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --watch src --exec node src/server.js",
    "dev:debug": "nodemon --inspect --watch src --exec node src/server.js",
    "seed:admin": "node src/scripts/seedAdmin.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "cross-env NODE_ENV=test jest --coverage --verbose",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "logs": "Get-Content logs/combined.log -Wait -Tail 50",
    "logs:error": "Get-Content logs/error.log -Wait -Tail 50",
    "logs:http": "Get-Content logs/http.log -Wait -Tail 50",
    "logs:all": "Get-Content logs/*.log -Wait -Tail 20",
    "logs:clear": "Remove-Item logs/*.log -Force",
    "db:health": "node scripts/checkDbHealth.js",
    "validate:env": "node scripts/validateEnv.js",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DARSHAN2224/hostel.git"
  },
  "keywords": [
    "hostel",
    "outpass"
  ],
  "author": "darshan",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DARSHAN2224/hostel/issues"
  },
  "homepage": "https://github.com/DARSHAN2224/hostel#readme",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/jest": "^29.5.11",
    "cross-env": "^10.1.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.3"
  }
}
