# ==============================================
# 🚀 PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env.production for production deployment
# NEVER commit actual credentials to version control!

# ==============================================
# 🌍 BASIC ENVIRONMENT
# ==============================================
NODE_ENV=production
PORT=5000

# ==============================================
# 🗄️ DATABASE CONFIGURATION
# ==============================================
# Production MongoDB URI (MongoDB Atlas, AWS DocumentDB, etc.)
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/hostel_management?retryWrites=true&w=majority
DB_NAME=hostel_management

# ==============================================
# 🔐 AUTHENTICATION & SECURITY
# ==============================================
# CRITICAL: Generate strong random secrets for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=REPLACE_WITH_DIFFERENT_STRONG_RANDOM_64_BYTE_HEX_STRING
REFRESH_TOKEN_EXPIRES_IN=30d

# Admin Registration Secret (Keep this extremely secure!)
ADMIN_REGISTRATION_SECRET=REPLACE_WITH_ULTRA_SECURE_RANDOM_STRING

# Initial Admin Credentials (Change immediately after first login!)
INITIAL_ADMIN_EMAIL=admin@yourdomain.com
INITIAL_ADMIN_PASSWORD=CHANGE_THIS_IMMEDIATELY_AFTER_FIRST_LOGIN

# ==============================================
# 🌐 CORS & API CONFIGURATION
# ==============================================
# Production frontend URL
CORS_ORIGIN=https://your-production-domain.com
CORS_CREDENTIALS=true

# ==============================================
# 🛡️ RATE LIMITING & SECURITY
# ==============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================
# 📁 FILE UPLOAD CONFIGURATION
# ==============================================
# For production, consider using S3, Cloudinary, or similar
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# ==============================================
# 📧 EMAIL CONFIGURATION (PRODUCTION)
# ==============================================
# Option 1: Gmail (Not recommended for high volume)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-production-email@gmail.com
# EMAIL_PASSWORD=your-app-specific-password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465

# Option 2: SendGrid (Recommended for production)
# EMAIL_SERVICE=SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=Hostel Management System

# Option 3: AWS SES (Highly recommended for AWS deployments)
# EMAIL_SERVICE=SES
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# EMAIL_FROM=noreply@yourdomain.com

# Option 4: Custom SMTP (e.g., Mailgun, Postmark)
EMAIL_SERVICE=smtp
EMAIL_HOST=smtp.yourmailprovider.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-username
EMAIL_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Hostel Management System
EMAIL_SECURE=true

# ==============================================
# 📝 LOGGING CONFIGURATION
# ==============================================
LOG_LEVEL=error
LOG_FILE=logs/production.log

# ==============================================
# 🎛️ FEATURE FLAGS
# ==============================================
ENABLE_REGISTRATION=false
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PASSWORD_RESET=true

# ==============================================
# 🔒 SSL/TLS CONFIGURATION
# ==============================================
# Path to SSL certificate and key (if using HTTPS directly in Node.js)
# SSL_CERT_PATH=/path/to/ssl/certificate.crt
# SSL_KEY_PATH=/path/to/ssl/private.key
# SSL_CA_PATH=/path/to/ssl/ca_bundle.crt

# ==============================================
# 💾 REDIS CONFIGURATION (Optional - for sessions/caching)
# ==============================================
# REDIS_URL=redis://username:password@redis-host:6379
# REDIS_PASSWORD=your-redis-password

# ==============================================
# ☁️ CLOUD STORAGE (Recommended for production)
# ==============================================
# AWS S3 Configuration
# AWS_BUCKET_NAME=your-bucket-name
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Cloudinary Configuration (Alternative to S3)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ==============================================
# 📱 SMS NOTIFICATIONS (Optional)
# ==============================================
# Twilio Configuration
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_PHONE_NUMBER=+1234567890

# ==============================================
# 🔍 MONITORING & ERROR TRACKING
# ==============================================
# Sentry for error tracking (Highly recommended)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=production

# New Relic APM (Optional)
# NEW_RELIC_LICENSE_KEY=your-new-relic-key
# NEW_RELIC_APP_NAME=Hostel Management API

# ==============================================
# 📊 ANALYTICS & METRICS
# ==============================================
# Google Analytics
# GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# ==============================================
# 🔐 SECURITY HEADERS & CSP
# ==============================================
# Content Security Policy
# CSP_ENABLED=true
# CSP_DIRECTIVES=default-src 'self'; script-src 'self' 'unsafe-inline'

# ==============================================
# ⚡ PERFORMANCE OPTIMIZATION
# ==============================================
# Node.js memory limit
# NODE_OPTIONS=--max-old-space-size=4096

# Cluster mode (for multi-core CPU utilization)
# CLUSTER_MODE=true
# CLUSTER_WORKERS=4

# ==============================================
# 🌍 DEPLOYMENT PLATFORM SPECIFIC
# ==============================================
# Heroku
# HEROKU_APP_NAME=your-app-name

# AWS Elastic Beanstalk
# AWS_EB_ENVIRONMENT=production

# DigitalOcean App Platform
# DO_APP_NAME=your-app-name

# Vercel/Netlify (for serverless deployments)
# VERCEL_URL=your-app.vercel.app
