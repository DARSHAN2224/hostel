# Server environment example
# Copy this to .env and fill values

# General
PORT=5000
MONGODB_URI=mongodb://localhost:27017/hostel
JWT_SECRET=your_jwt_secret_here

# SMS provider: 'mock' for development (logs SMS to console), 'twilio' to send real SMS
SMS_PROVIDER=mock

# Twilio (only required when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Optional: other providers can be integrated similarly
