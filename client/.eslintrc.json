{
  "extends": ["eslint:recommended", "plugin:react/recommended"],
  "plugins": ["react"],
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "react/prop-types": "off",
    "react/jsx-pascal-case": ["error", {
      "allowAllCaps": false,
      "allowLeadingUnderscore": false,
      "allowNamespace": true,
      "ignore": ["Motion"]
    }],
    "no-restricted-globals": "off",
    "consistent-return": "off"
  }
}
